# Copy to .env and fill in. .env is gitignored.
# Runtime connections use the non-superuser, RLS-enforced role `uaid_app`.
# Set RLS_DB_PASSWORD and use the SAME value in these URLs (the Makefile injects it).
RLS_DB_PASSWORD=
DATABASE_URL=postgresql+asyncpg://uaid_app:CHANGE_ME@localhost:5432/app
TEST_DATABASE_URL=postgresql+asyncpg://uaid_app:CHANGE_ME@localhost:5432/app_test
# Admin (owner/superuser) connections — migrations / role bootstrap / test seed only.
ADMIN_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
TEST_ADMIN_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app_test
REDIS_URL=redis://localhost:6379/0
CHROMA_URL=http://localhost:8001
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
